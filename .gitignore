# --- Python env / caches ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.python-version

# --- External clones (reproducible; not vendored) ---
# gym-pusht: the immutable Push-T env. Re-create with:
#   git clone https://github.com/huggingface/gym-pusht && uv pip install -e gym-pusht
gym-pusht/
# autoresearch: reference only. git clone https://github.com/karpathy/autoresearch
reference_autoresearch/

# --- Generated reports ---
# Track lightweight, durable result artifacts (figures, iteration/merge logs, summaries);
# ignore heavy media (rollout videos/trajectories) and per-run scratch (_*.log).
# NOTE: .gitignore has no inline comments — keep patterns on their own lines.
enpire_sim/reports/rollouts/
enpire_sim/reports/*.mp4
enpire_sim/reports/*.gif
enpire_sim/reports/_*
enpire_sim/reports/continue_prompt.txt
*.npz

# --- Heavy pulled assets (kept locally, too big for git) ---
# Website reference clips + paper PDF. Lightweight reference (svg/json/recovered
# code) IS tracked; the large media is not. Add Git LFS if you want them in-repo.
pusht_components/*.mp4
*.pdf

# --- Scratch ---
site.html

# Stage 2 fleet worktrees (sibling dir, auto-created)
.worktrees/
